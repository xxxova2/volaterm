# Trading Terminal Pro — Environment Configuration

# Server
PORT=3001

# REQUIRED for live market data (option chain, quotes, treasury rates).
# Get a key at https://financialmodelingprep.com/ and set it here.
# Without it, the server still runs but live mode and FMP enrichment return 503.
FMP_API_KEY=your_fmp_key_here

# Comma-separated list of origins allowed by CORS. Defaults to localhost dev origins.
# Set this to your deployed frontend URL in production, e.g.:
# CORS_ORIGIN=https://your-app.vercel.app

# Yahoo Finance fallback (Python yfinance) — optional; FMP is the default live source.
# YAHOO_API_KEY=your_key_here

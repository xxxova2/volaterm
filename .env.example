# Trading Terminal Pro — Environment Configuration

# Server
PORT=3001

# REQUIRED for live market data (option chain, quotes, treasury rates).
# Get a key at https://financialmodelingprep.com/ and set it here.
# Without it, the server still runs but live mode and FMP enrichment return 503.
FMP_API_KEY=your_fmp_key_here

# Comma-separated list of origins allowed by CORS. Defaults to localhost dev origins.
# Set this to your deployed frontend URL in production, e.g.:
# CORS_ORIGIN=https://your-app.vercel.app

# Yahoo Finance fallback (Python yfinance) — optional; FMP is the default live source.
# YAHOO_API_KEY=your_key_here

# MacroVol FastAPI (FRED macro/rates + yfinance greeks/IV surface).
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
# Put FRED_API_KEY in macrovol-api/.env (preferred) or export before starting the API.
# FRED_API_KEY=your_fred_key_here
# MACROVOL_API_URL=http://127.0.0.1:8765
# ALLOW_STIR_FALLBACK=0   # keep 0: never mix stale SR3/ZQ fallbacks with live quotes

# OPRA paid options stream (PR-10 skeleton — off by default)
# Do not put vendor secrets in the browser. Server-only.
# OPRA_ENABLED=0
# OPRA_VENDOR=stub          # stub | polygon | livevol
# OPRA_API_KEY=             # future vendor credential (server-side only)

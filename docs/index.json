    {
      "id": "glossary",
      "label": "Glossary",
      "description": "Term-first definitions. Quiz yourself.",
      "entries": [
        {
          "term": "GEX",
          "definition": "Gamma Exposure \u2014 estimated dealer gamma by strike/expiry from OI under a stated convention. Positive GEX: dealers tend to dampen moves; negative GEX: amplify.",
          "category": "positioning"
        },
        {
          "term": "DEX",
          "definition": "Delta Exposure \u2014 net delta by strike (often dealer-signed). Shows directional hedge pressure as spot walks, distinct from gamma convexity.",
          "category": "positioning"
        },
        {
          "term": "Flip / Gamma flip",
          "definition": "Price region where dealer gamma changes sign from positive to negative (or reverse). A pivot for dampen vs amplify regimes.",
          "category": "positioning"
        },
        {
          "term": "Call wall / Call resistance",
          "definition": "Strike with large call OI/GEX mass above spot; educational magnet/resistance from hedging, not classical TA.",
          "category": "positioning"
        },
        {
          "term": "Put wall / Put support",
          "definition": "Strike with large put OI/GEX mass below spot; educational support magnet from hedging.",
          "category": "positioning"
        },
        {
          "term": "HVL",
          "definition": "High Vol Level \u2014 profile reference often at max |GEX| or vendor 'vol magnet' strike; separates structural regimes on the chart.",
          "category": "positioning"
        },
        {
          "term": "Charm",
          "definition": "\u2202\u0394/\u2202t \u2014 delta change from time passage alone. Drives dealer futures hedges even if spot is flat; critical for 0DTE path bias.",
          "category": "options"
        },
        {
          "term": "Vanna",
          "definition": "\u2202\u0394/\u2202\u03c3 (or \u2202\u03bd/\u2202S) \u2014 links spot hedges to IV shocks. Crash books and skew dynamics live here.",
          "category": "options"
        },
        {
          "term": "Volga / Vomma",
          "definition": "\u2202\u03bd/\u2202\u03c3 \u2014 convexity of value with respect to implied volatility. Punishes casual short wings when IV jumps.",
          "category": "options"
        },
        {
          "term": "Theta (\u03b8)",
          "definition": "Time decay of option value. For shorts: compensation for asymmetric risk (gamma/vanna/volga), not free income.",
          "category": "options"
        },
        {
          "term": "Gamma (\u0393)",
          "definition": "\u2202\u00b2V/\u2202S\u00b2 = \u2202\u0394/\u2202S. Long options positive. Drives rehedging frequency and GEX construction.",
          "category": "options"
        },
        {
          "term": "Delta (\u0394)",
          "definition": "\u2202V/\u2202S. Share-equivalent directional exposure. Migrates with spot, time (charm), and vol (vanna).",
          "category": "options"
        },
        {
          "term": "Vega (\u03bd)",
          "definition": "\u2202V/\u2202\u03c3. Sensitivity to implied volatility, often quoted per 1 vol point.",
          "category": "options"
        },
        {
          "term": "Taylor / GVV identity",
          "definition": "dV \u2248 \u03b8 dt + \u0394 dx + \u03bd d\u03c3 + \u00bd\u0393(dx)\u00b2 + \u00bdVolga(d\u03c3)\u00b2 + Vanna dx d\u03c3. Desk language for P&L attribution.",
          "category": "options"
        },
        {
          "term": "0DTE",
          "definition": "Options expiring the same day. Extreme gamma/theta concentration; stack vs longer-dated gamma before reading path.",
          "category": "options"
        },
        {
          "term": "VRP",
          "definition": "Variance risk premium \u2014 tendency for implied variance to exceed realized on average for many equity indices; not a daily free lunch.",
          "category": "options"
        },
        {
          "term": "Contango (vol)",
          "definition": "Term structure with longer-dated IV above shorter-dated IV; common calm equity-index shape.",
          "category": "options"
        },
        {
          "term": "Backwardation (vol)",
          "definition": "Front IV above back IV; often stress or near-term event demand.",
          "category": "options"
        },
        {
          "term": "Skew / Smile",
          "definition": "IV varying by strike. Equity indices typically show put skew (downside insurance expensive).",
          "category": "options"
        },
        {
          "term": "Sticky strike / sticky delta",
          "definition": "Rules of thumb for how the smile moves when spot moves; changes effective vanna/volga P&L.",
          "category": "options"
        },
        {
          "term": "Pin risk",
          "definition": "Risk that spot gravitates to a large OI strike into expiry due to hedging; pin vanishes after expiry.",
          "category": "positioning"
        },
        {
          "term": "OI dealer convention",
          "definition": "Assumption (e.g. customers long options \u21d2 dealers short) used to sign GEX/DEX. Model, not a full participant tape.",
          "category": "positioning"
        },
        {
          "term": "Trapdoor",
          "definition": "Educational fragility: negative gamma below a level combined with fat put skew \u2014 breaks can amplify with rising IV.",
          "category": "positioning"
        },
        {
          "term": "Buy-or-buy mode",
          "definition": "Dealer gamma profile such that both downside and upside scenarios require buying deltas to hedge \u2014 a flow skew, not a guarantee of rallies.",
          "category": "positioning"
        },
        {
          "term": "SOFR",
          "definition": "Secured Overnight Financing Rate \u2014 broad cost of borrowing cash overnight vs Treasury collateral (repo complex).",
          "category": "macro"
        },
        {
          "term": "EFFR",
          "definition": "Effective Federal Funds Rate \u2014 unsecured overnight bank reserves market; often residual/regulatory in abundant-reserves regimes.",
          "category": "macro"
        },
        {
          "term": "IORB",
          "definition": "Interest on Reserve Balances \u2014 rate Fed pays on reserves; anchors bank reserve remuneration.",
          "category": "macro"
        },
        {
          "term": "RRP / ON RRP",
          "definition": "Overnight reverse repo facility \u2014 floor tool and cash sponge for eligible counterparties (e.g. money funds).",
          "category": "macro"
        },
        {
          "term": "SRF",
          "definition": "Standing Repo Facility \u2014 ceiling-style backstop lending cash vs Treasuries to limit repo spikes.",
          "category": "macro"
        },
        {
          "term": "SOFR\u2212EFFR spread",
          "definition": "Barometer of dealer/balance-sheet capacity: SOFR above EFFR often signals scarce balance sheet / abundant collateral pressure.",
          "category": "macro"
        },
        {
          "term": "GC repo",
          "definition": "General collateral repo \u2014 financing against generic eligible Treasuries; SOFR summarizes this complex.",
          "category": "macro"
        },
        {
          "term": "Specialness",
          "definition": "GC rate minus special repo rate for a scarce CUSIP; deep specials signal squeeze/scarcity.",
          "category": "macro"
        },
        {
          "term": "SLR",
          "definition": "Supplementary Leverage Ratio \u2014 capital vs leverage exposure; taxes balance-sheet intensive intermediation like matched-book repo.",

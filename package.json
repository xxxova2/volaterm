{
  "name": "trading-terminal-pro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api,macro \"vite\" \"node server.js\" \"npm run macrovol-api\"",
    "macrovol-api": "python3 -m uvicorn main:app --app-dir macrovol-api --host 127.0.0.1 --port 8765",
    "build": "tsc -b && vite build",
    "start": "node server.js",
    "start:prod": "bash scripts/start-production.sh",
    "type-check": "tsc --noEmit",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "NODE_ENV=test vitest",
    "test:ui": "NODE_ENV=test vitest --ui",
    "test:coverage": "NODE_ENV=test vitest --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^11.0.1",
    "@fastify/static": "^8.1.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fastify": "^5.3.2",
    "lucide-react": "^0.575.0",
    "plotly.js-dist-min": "^3.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-plotly.js": "^4.0.0",
    "react-window": "^2.2.7",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.185.0",
    "tw-animate-css": "^1.3.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.6.5",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^2.0.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^3.0.9",
    "concurrently": "^9.1.2",
    "jsdom": "^26.1.0",
    "oxlint": "^1.69.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^3.0.9"
  }
}
